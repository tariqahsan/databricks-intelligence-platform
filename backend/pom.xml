<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">

  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>4.0.5</version>
    <relativePath/>
  </parent>

  <groupId>mil.disa.oe</groupId>
  <artifactId>oe-data-intelligence</artifactId>
  <version>1.0.0</version>
  <name>DISA OE Data Intelligence Platform</name>
  <description>
    Operations Engineering Data Intelligence Platform POC -
    Databricks-backed analytics for NETCOOL, DXNETOPS, ElastiFlow,
    Netscout, and DataNX data sources.
  </description>

  <properties>
    <java.version>21</java.version>
    <databricks-jdbc.version>2.6.38</databricks-jdbc.version>
    <caffeine.version>3.1.8</caffeine.version>
    <spring-retry.version>2.0.6</spring-retry.version>

    <!--
      UTF-8 source encoding.
      Prevents "illegal character" compile errors when Java source files
      contain any non-ASCII characters (e.g. Unicode in Javadoc comments).
      Without this, Maven uses the OS default encoding (Windows-1252 on
      Windows) which rejects characters outside the Latin-1 range.
    -->
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

    <!--
      JDK 21 compatibility flags for Hive JDBC 3.1.x.
      Hive was built for JDK 8 and uses deep reflection internally.
      These add-opens directives grant Hive the access it needs
      without recompiling or patching the Hive JAR.

      Applied to:
        - mvn spring-boot:run   (local dev)
        - java -jar app.jar     (fat JAR via MANIFEST.MF)
        - mvn test              (unit tests via Surefire)

      NOT needed for AWS Databricks - Databricks JDBC is JDK 21 native.
      Only needed for local Spark Thrift Server (thrift profile).
    -->
    <jvm.opens>
      --add-opens java.base/sun.nio.ch=ALL-UNNAMED
      --add-opens java.base/java.nio=ALL-UNNAMED
      --add-opens java.base/java.lang=ALL-UNNAMED
      --add-opens java.base/java.lang.reflect=ALL-UNNAMED
      --add-opens java.base/java.io=ALL-UNNAMED
      --add-opens java.base/java.util=ALL-UNNAMED
      --add-opens java.base/java.util.concurrent=ALL-UNNAMED
      --add-opens java.base/java.net=ALL-UNNAMED
      --add-opens java.base/java.security=ALL-UNNAMED
      --add-opens java.base/sun.security.action=ALL-UNNAMED
      --add-opens java.base/sun.net.dns=ALL-UNNAMED
    </jvm.opens>
  </properties>

  <dependencies>

    <!-- Web -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>

    <!-- JDBC - primary data access layer -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-jdbc</artifactId>
    </dependency>

    <!-- Validation -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-validation</artifactId>
    </dependency>

    <!-- Cache + Caffeine -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-cache</artifactId>
    </dependency>
    <dependency>
      <groupId>com.github.ben-manes.caffeine</groupId>
      <artifactId>caffeine</artifactId>
      <version>${caffeine.version}</version>
    </dependency>

    <!-- Spring Retry - SQL Warehouse cold-start resilience -->
    <dependency>
      <groupId>org.springframework.retry</groupId>
      <artifactId>spring-retry</artifactId>
      <version>${spring-retry.version}</version>
    </dependency>
    <dependency>
      <groupId>org.springframework</groupId>
      <artifactId>spring-aspects</artifactId>
    </dependency>

    <!--
      Databricks JDBC Driver - AWS GovCloud production.
      JDK 21 native. No add-opens needed.
      Profile: application.yml (default/prod)
      URL: jdbc:databricks://host:443/default;httpPath=...;PWD=dapi-token

      Install into local Maven repo before building (one-time):
        mvn install:install-file
          -Dfile=DatabricksJDBC42.jar
          -DgroupId=com.databricks
          -DartifactId=databricks-jdbc
          -Dversion=2.6.38
          -Dpackaging=jar
    -->
    <dependency>
      <groupId>com.databricks</groupId>
      <artifactId>databricks-jdbc</artifactId>
      <version>${databricks-jdbc.version}</version>
    </dependency>

    <!--
      Hive JDBC Driver - local Spark Thrift Server.
      CHECKED INTO REPO at: libs/hive-jdbc-3.1.3-standalone.jar

      This is a PATCHED version of the official Hive 3.1.3 standalone JAR.
      Two directories were removed from the original to fix Spring Boot 4
      incompatibilities:

        org/slf4j/ - Hive bundles SLF4J 1.x which conflicts with
                     Spring Boot 4's SLF4J 2.x / Logback binding.
                     Symptom: "LoggerFactory is not a Logback context"

        org/apache/jasper/ - Hive bundles old Tomcat Jasper using
                             javax.servlet, but Spring Boot 4 uses
                             jakarta.servlet (Jakarta EE 10).
                             Symptom: "JspServlet cannot be cast to Servlet"

      WHY system scope?
        system scope uses the JAR file directly without resolving Hive's
        POM or any transitive dependencies. This means none of Hive's
        conflicting log4j bridges, jdk.tools phantom deps, or other
        JDK 8-era artifacts appear on the classpath. No exclusions
        needed - the problem simply does not exist.

      WHY checked into git?
        The patching is a one-time surgical fix that cannot be expressed
        in pom.xml (Maven exclusions only work on separate artifacts,
        not on class files bundled inside a fat JAR). Checking in the
        patched JAR ensures every developer gets a working build with
        zero manual steps after git clone.

      Profile: application-thrift.yml (thrift profile)
      URL: jdbc:hive2://localhost:10000/default
    -->
    <dependency>
      <groupId>org.apache.hive</groupId>
      <artifactId>hive-jdbc</artifactId>
      <version>3.1.3</version>
      <classifier>standalone</classifier>
      <scope>system</scope>
      <systemPath>${project.basedir}/libs/hive-jdbc-3.1.3-standalone.jar</systemPath>
    </dependency>

    <!--
      H2 - local mock profile only.
      Profile: application-local.yml (local,mock)
      Zero external dependencies - works immediately with no setup.
    -->
    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
      <scope>runtime</scope>
    </dependency>

    <!-- Actuator -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-actuator</artifactId>
    </dependency>

    <!-- Test -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-test</artifactId>
      <scope>test</scope>
    </dependency>

  </dependencies>

  <build>
    <plugins>

      <!--
        Spring Boot Maven Plugin.
        includeSystemScope: packages the system-scoped Hive JAR into
        BOOT-INF/lib inside the fat JAR so it is available at runtime
        when running: java -jar app.jar
        jvmArguments: add-opens for Hive JDBC on JDK 21, applied when
        running mvn spring-boot:run and written into MANIFEST.MF.
      -->
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
        <configuration>
          <includeSystemScope>true</includeSystemScope>
          <jvmArguments>${jvm.opens}</jvmArguments>
        </configuration>
      </plugin>

      <!--
        Compiler Plugin - explicit JDK 21 + UTF-8.
        The encoding element here is belt-and-suspenders with the
        project.build.sourceEncoding property defined above - both
        are needed for full coverage across all Maven plugin versions.
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <configuration>
          <source>21</source>
          <target>21</target>
          <encoding>UTF-8</encoding>
        </configuration>
      </plugin>

      <!--
        Surefire - apply add-opens to unit tests as well.
        Hive JDBC reflection access is needed in test-scoped code too.
      -->
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <argLine>${jvm.opens}</argLine>
        </configuration>
      </plugin>

    </plugins>
  </build>

</project>